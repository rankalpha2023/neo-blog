---
// src/pages/about.astro — 关于页（AI 主题，无 GEO）
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuthorCard from "../components/AuthorCard.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title="关于 Neo Blog — AI 工具与智能实践"
      description="了解 Neo Blog：这是一个探索 AI 工具与智能实践的个人博客，涵盖编程助手、Agent 自动化、LLM 应用开发、知识管理和多模态应用等方向，记录 AI 时代的效率提升之路"
    />
  </head>
  <body class="bg-[var(--color-surface-base)] text-[var(--color-text-primary)]">
    <Header />

    <main class="mx-auto max-w-3xl px-4 py-12">
      <h1 class="text-3xl font-extrabold mb-8 tracking-tight">
        关于 <span class="bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">Neo Blog</span>
      </h1>

      <div class="prose max-w-none">
        <p>
          欢迎来到 <strong>Neo Blog</strong>。
        </p>

        <p>
          这是一个探索 <strong>AI 工具与智能实践</strong>的个人博客。
          从编程助手到 Agent 自动化，从知识管理到多模态应用——
          这里记录的是在 AI 时代中，如何用工具提升效率、用方法论指导实践的思考与经验。
        </p>

        <h2>关注方向</h2>

        <ul>
          <li><strong>AI 编程助手</strong> — Claude Code、Cursor 等工具的深度对比与实践</li>
          <li><strong>Agent 自动化</strong> — 构建 AI Agent 的架构设计与实战落地</li>
          <li><strong>LLM 应用开发</strong> — Prompt 工程、RAG、评估体系的避坑指南</li>
          <li><strong>知识管理</strong> — AI 原生的个人知识管理新范式</li>
          <li><strong>多模态应用</strong> — 让 AI 看懂图片、理解设计的实战技巧</li>
        </ul>

        <h2>技术栈</h2>

        <table>
          <tr><th>技术</th><th>用途</th></tr>
          <tr><td>Astro 6</td><td>静态站点生成器</td></tr>
          <tr><td>Tailwind CSS v4</td><td>样式框架（OKLCH 色彩空间）</td></tr>
          <tr><td>Cloudflare Pages</td><td>全球 CDN 部署</td></tr>
          <tr><td>@jdevalk/astro-seo-graph</td><td>一站式 SEO 解决方案</td></tr>
          <tr><td>Markdown / MDX</td><td>内容写作格式</td></tr>
        </table>

        <h2>设计理念</h2>

        <p>
          本站采用「<strong>柠檬海盐</strong>」配色方案——明亮、清爽、有活力。
          使用 OKLCH 色彩空间确保感知均匀，支持浅色/深色模式自由切换。
        </p>
      </div>

      <!-- 作者卡 -->
      <AuthorCard name="Neo" class="mt-12" />
    </main>

    <Footer />
  </body>
</html>
