---
// src/pages/index.astro — 首页「柠檬海盐」版（AI 主题）
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TagList from "../components/TagList.astro";
import { getCollection } from "astro:content";
import "../styles/global.css";

const posts = (
  await getCollection("blog", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title="Neo Blog — 探索 AI 工具与智能实践"
      description="Neo Blog 是一个探索 AI 工具与智能实践的个人博客，涵盖 AI 编程助手、Agent 自动化、LLM 应用开发、知识管理和多模态应用，记录 AI 时代的效率提升之路"
    />
  </head>
  <body class="bg-[var(--color-surface-base)] text-[var(--color-text-primary)]">
    <Header />

    <main class="mx-auto max-w-3xl px-4 py-12">
      <!-- ====== Hero 区域 ====== -->
      <section class="mb-16 text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-5 tracking-tight">
          <span class="block text-[var(--color-text-primary)]">探索</span>
          <span class="block bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">
            AI 工具与实践
          </span>
        </h1>

        <p class="text-base md:text-lg text-[var(--color-text-muted)] max-w-xl mx-auto leading-relaxed mb-8">
          从编程助手到 Agent 自动化，从知识管理到多模态应用。<br class="hidden md:block" />
          记录 AI 时代的效率提升之路。
        </p>

        <!-- 渐变分隔线 -->
        <div class="mx-auto w-24 h-0.5 rounded-full" style="background: linear-gradient(to right, transparent, var(--color-primary-glow), var(--color-accent), transparent);"></div>
      </section>

      <!-- ====== 最新文章列表 ====== -->
      <section>
        <h2 class="text-xl font-bold mb-8 flex items-center gap-2 text-[var(--color-text-secondary)]">
          <span class="inline-block w-1.5 h-6 rounded-full bg-[var(--color-primary)]"></span>
          最新文章
        </h2>

        {posts.length === 0 ? (
          <div class="text-center py-16 text-[var(--color-text-muted)] border border-dashed border-[var(--color-surface-highest)] rounded-xl bg-[var(--color-surface-low)]">
            <p class="text-lg font-medium">还没有文章</p>
            <p class="text-sm mt-2 opacity-70">在 src/content/blog/ 下创建 .md 文件即可</p>
          </div>
        ) : (
          <div class="space-y-5">
            {posts.map((post) => (
              <article
                class="group relative pl-5 pr-5 pt-5 pb-5 rounded-xl bg-[var(--color-surface-raised)] hover:shadow-lg transition-all duration-200 overflow-hidden"
                style="border-left: 3px solid var(--color-tag-ai);"
              >
                {/* 左侧彩色条动画 */}
                <span
                  class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[var(--color-primary)] to-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                  style="width: 3px; margin-left: -3px;"
                ></span>

                {post.data.tags.length > 0 && (
                  <div class="mb-2.5">
                    <TagList tags={post.data.tags} size="sm" />
                  </div>
                )}

                <a
                  href={`/blog/${post.id}`}
                  class="text-lg md:text-xl font-bold block mb-2 group-hover:text-[var(--color-primary)] transition-colors duration-200"
                >
                  {post.data.title}
                </a>

                {post.data.description && (
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                )}

                <div class="flex items-center justify-between text-xs text-[var(--color-text-muted)] mt-auto pt-1">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  {post.data.author && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                      {post.data.author}
                    </span>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>

    <Footer />
  </body>
</html>
