---
// src/components/Footer.astro — 页脚「柠檬海盐」版（AI 主题）
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-surface-highest)] mt-20 bg-[var(--color-surface-low)]">
  <div class="mx-auto max-w-3xl px-4 py-10 text-center">
    <!-- Logo 小字 -->
    <p class="text-sm font-semibold text-[var(--color-text-primary)] mb-2">
      <span class="bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">Neo</span>Blog
    </p>
    <!-- 分隔线 -->
    <div class="mx-auto w-12 h-px rounded-full bg-[var(--color-surface-highest)] my-4"></div>
    <!-- 版权信息 -->
    <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
      &copy; {year} Neo Blog &middot; 用
      <a href="https://astro.build" target="_blank" rel="noopener" class="text-[var(--color-primary)] hover:underline underline-offset-2">Astro</a>
      +
      <a href="https://pages.cloudflare.com/" target="_blank" rel="noopener" class="text-[var(--color-primary)] hover:underline underline-offset-2">Cloudflare</a>
      构建
    </p>
    <p class="text-xs text-[var(--color-text-muted)] mt-1 opacity-70">
      探索 AI 工具与智能实践
    </p>
  </div>
</footer>
