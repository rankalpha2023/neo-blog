---
// src/components/Header.astro — 导航栏 + 主题切换器
import ThemeSwitcher from "./ThemeSwitcher.astro";

const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog", label: "博客" },
  { href: "/about", label: "关于" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-[var(--color-surface-base)]/80 border-b border-[var(--color-surface-highest)]">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3.5">
    <!-- Logo -->
    <a
      href="/"
      class="text-lg font-extrabold tracking-tight text-[var(--color-text-primary)] hover:text-[var(--color-primary)] transition-colors duration-200"
    >
      <span class="bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">
        Neo
      </span>
      <span class="text-[var(--color-text-primary)]">Blog</span>
    </a>

    <!-- 导航链接 + 主题切换 -->
    <div class="flex items-center gap-1">
      <nav class="flex gap-1">
        {navItems.map((item) => {
          const isActive =
            currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href));

          return (
            <a
              href={item.href}
              class:list={[
                "relative px-3 py-1.5 text-sm font-medium transition-colors duration-200 rounded-md",
                isActive
                  ? "text-[var(--color-primary)]"
                  : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-raised)]",
              ]}
            >
              {item.label}
              {/* 当前页面底部粗线指示器 */}
              {isActive && (
                <span class="absolute bottom-0 left-2 right-2 h-0.5 rounded-full bg-[var(--color-primary)]"></span>
              )}
            </a>
          );
        })}
      </nav>

      <!-- 分隔线 -->
      <div class="w-px h-5 bg-[var(--color-surface-highest)] mx-1"></div>

      <!-- 主题切换按钮 -->
      <ThemeSwitcher />
    </div>
  </div>
</header>
